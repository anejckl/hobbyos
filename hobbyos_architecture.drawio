        <mxCell id="t4_7" value="&lt;b&gt;Self-Hosting&lt;/b&gt;&lt;hr&gt;Port a C compiler (tcc?)&lt;br&gt;to compile programs within&lt;br&gt;the OS itself." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
