  </diagram>
  <diagram id="roadmap" name="Roadmap">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="rm_title" value="HobbyOS — Development Roadmap" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rm_subtitle" value="Current: 48 syscalls • 18 shell commands • 45+ user programs • Networking • ext2 R/W + Journal • Demand Paging + Swap • Security Model" style="text;html=1;fontSize=12;fontStyle=2;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="250" y="48" width="1100" height="22" as="geometry" />
        </mxCell>
        <!-- ═══════════ COMPLETED ═══════════ -->
        <mxCell id="done_group" value="" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#F1F8E9;strokeColor=#558B2F;strokeWidth=3;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="1520" height="200" as="geometry" />
        </mxCell>
        <mxCell id="done_label" value="COMPLETED (Phases 16-20)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#33691E;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="done_badge" value="DONE" style="text;html=1;fontSize=13;fontStyle=1;align=right;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="1350" y="95" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="&lt;b&gt;Free-List Allocator&lt;/b&gt;&lt;hr&gt;Replaced bump kheap with&lt;br&gt;first-fit + coalescing.&lt;br&gt;kfree() now works!" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="175" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="&lt;b&gt;Demand Paging + Swap&lt;/b&gt;&lt;hr&gt;VMA_ELF lazy page alloc.&lt;br&gt;CLOCK eviction to 16MB swap.&lt;br&gt;Rmap + page cache (512)." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="245" y="130" width="195" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="&lt;b&gt;Security Model&lt;/b&gt;&lt;hr&gt;uid/gid/euid/egid, cred.c,&lt;br&gt;chmod/chown, setuid binaries.&lt;br&gt;7 new syscalls (40-46)." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="450" y="130" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="&lt;b&gt;Storage Reliability&lt;/b&gt;&lt;hr&gt;Block cache (256, hash+LRU).&lt;br&gt;Write-ahead journal (redo).&lt;br&gt;sync shell command." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="130" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d5" value="&lt;b&gt;Device Management&lt;/b&gt;&lt;hr&gt;64-device registry, device_ops.&lt;br&gt;Driver model (probe/init).&lt;br&gt;Hierarchical devfs, /dev/random." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="830" y="130" width="205" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d6" value="&lt;b&gt;Advanced Networking&lt;/b&gt;&lt;hr&gt;Non-blocking sockets, EPOLLET.&lt;br&gt;sendfile, dual-pool netbufs&lt;br&gt;with refcounting. fcntl." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1045" y="130" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="d7" value="&lt;b&gt;New Programs&lt;/b&gt;&lt;hr&gt;id, whoami, demand_test&lt;br&gt;perm_test, nonblock_test&lt;br&gt;+6 host test suites" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#DCEDC8;strokeColor=#558B2F;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1255" y="130" width="175" height="90" as="geometry" />
        </mxCell>
        <!-- ═══════════ TIER 1 ═══════════ -->
        <mxCell id="t1_group" value="" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=3;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="1520" height="220" as="geometry" />
        </mxCell>
        <mxCell id="t1_label" value="TIER 1 — Foundation Gaps (High Impact, Medium Effort)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t1_priority" value="DO NEXT" style="text;html=1;fontSize=13;fontStyle=1;align=right;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="1350" y="310" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t1_2" value="&lt;b&gt;Kernel Threads&lt;/b&gt;&lt;hr&gt;Lightweight tasks sharing the&lt;br&gt;kernel address space. Needed&lt;br&gt;for background daemons,&lt;br&gt;async I/O workers." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t1_3" value="&lt;b&gt;Process Groups &amp;amp; Sessions&lt;/b&gt;&lt;hr&gt;setsid, setpgid, controlling&lt;br&gt;terminal. Required for proper&lt;br&gt;job control (fg/bg/jobs)." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="275" y="350" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t1_5" value="&lt;b&gt;Shell I/O Redirection&lt;/b&gt;&lt;hr&gt;Support &amp;gt;, &amp;gt;&amp;gt;, &amp;lt;, 2&amp;gt;&amp;amp;1&lt;br&gt;in the shell. Uses existing&lt;br&gt;dup2 + open syscalls." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="350" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t1_6" value="&lt;b&gt;DHCP Client&lt;/b&gt;&lt;hr&gt;Auto-configure IP instead of&lt;br&gt;hardcoded. UDP port 67/68.&lt;br&gt;&lt;br&gt;&lt;b&gt;DNS Resolver&lt;/b&gt;&lt;hr&gt;Hostname → IP lookup." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="715" y="350" width="200" height="150" as="geometry" />
        </mxCell>
        <mxCell id="t1_7" value="&lt;b&gt;User Accounts&lt;/b&gt;&lt;hr&gt;login program, /etc/passwd,&lt;br&gt;password hashing, su. Build&lt;br&gt;on Phase 17 credentials." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="930" y="350" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t1_8" value="&lt;b&gt;Integrate Block Cache&lt;/b&gt;&lt;hr&gt;Route ext2_read/write_block&lt;br&gt;through bcache. Currently&lt;br&gt;block cache exists but ext2&lt;br&gt;still does direct ATA I/O." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1145" y="350" width="200" height="120" as="geometry" />
        </mxCell>
        <!-- Dependency arrow: Process Groups needed before Shell I/O -->
        <mxCell id="t1_dep1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2E7D32;strokeWidth=2;dashed=1;" edge="1" source="t1_3" target="t1_5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ═══════════ TIER 2 ═══════════ -->
        <mxCell id="t2_group" value="" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=3;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="535" width="1520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="t2_label" value="TIER 2 — Hardware &amp; Performance (Medium Impact, High Effort)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="60" y="545" width="550" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t2_priority" value="PERFORMANCE" style="text;html=1;fontSize=13;fontStyle=1;align=right;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1350" y="545" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t2_1" value="&lt;b&gt;SMP / Multi-Core&lt;/b&gt;&lt;hr&gt;AP startup via SIPI, per-CPU&lt;br&gt;scheduler run queues, spinlocks&lt;br&gt;for shared data structures." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t2_2" value="&lt;b&gt;APIC + IOAPIC&lt;/b&gt;&lt;hr&gt;Replace 8259 PIC. Required&lt;br&gt;for SMP. Parse MADT ACPI&lt;br&gt;table, per-CPU LAPIC." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="280" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t2_3" value="&lt;b&gt;ATA DMA / AHCI&lt;/b&gt;&lt;hr&gt;Replace PIO disk I/O with&lt;br&gt;DMA transfers. AHCI for&lt;br&gt;SATA. Frees CPU." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t2_4" value="&lt;b&gt;USB Stack&lt;/b&gt;&lt;hr&gt;xHCI/EHCI host controller.&lt;br&gt;HID class for USB keyboard&lt;br&gt;and mouse." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="720" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t2_5" value="&lt;b&gt;ACPI&lt;/b&gt;&lt;hr&gt;Shutdown, reboot, power mgmt.&lt;br&gt;RSDP → RSDT → FADT/MADT.&lt;br&gt;CPU topology for SMP." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="940" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t2_6" value="&lt;b&gt;Virtio Drivers&lt;/b&gt;&lt;hr&gt;virtio-blk, virtio-net.&lt;br&gt;Paravirtualized — faster&lt;br&gt;than emulated e1000/ATA." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1160" y="585" width="200" height="120" as="geometry" />
        </mxCell>
        <!-- SMP depends on APIC -->
        <mxCell id="t2_dep1" value="requires" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C62828;strokeWidth=2;fontColor=#C62828;fontSize=10;" edge="1" source="t2_1" target="t2_2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t2_dep2" value="needs MADT" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C62828;strokeWidth=1;dashed=1;fontColor=#C62828;fontSize=9;" edge="1" source="t2_2" target="t2_5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ═══════════ TIER 3 ═══════════ -->
        <mxCell id="t3_group" value="" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=3;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="1520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="t3_label" value="TIER 3 — Userland &amp; UX (Medium Impact, Medium Effort)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="60" y="790" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t3_priority" value="USABILITY" style="text;html=1;fontSize=13;fontStyle=1;align=right;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="1350" y="790" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t3_1" value="&lt;b&gt;POSIX termios&lt;/b&gt;&lt;hr&gt;Raw mode, cooked mode,&lt;br&gt;tcsetattr/tcgetattr. Enables&lt;br&gt;text editors, ncurses TUIs." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_2" value="&lt;b&gt;Virtual Terminals&lt;/b&gt;&lt;hr&gt;Ctrl+Alt+F1..F6 switching.&lt;br&gt;Each VT has its own buffer,&lt;br&gt;input stream, and shell." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="280" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_3" value="&lt;b&gt;Symlinks &amp;amp; Hardlinks&lt;/b&gt;&lt;hr&gt;Symbolic and hard links in&lt;br&gt;ext2. ln, readlink. Path&lt;br&gt;resolution follows symlinks." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_4" value="&lt;b&gt;Shell Scripting&lt;/b&gt;&lt;hr&gt;Variables ($VAR), if/else,&lt;br&gt;while loops, script files&lt;br&gt;(#!/bin/sh), /etc/rc." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="720" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_5" value="&lt;b&gt;Window Manager v2&lt;/b&gt;&lt;hr&gt;Real compositor with Z-order,&lt;br&gt;window decorations, move/&lt;br&gt;resize. Double buffering." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="940" y="830" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_6" value="&lt;b&gt;/tmp tmpfs&lt;/b&gt;&lt;hr&gt;RAM-backed temporary FS.&lt;br&gt;&lt;br&gt;&lt;b&gt;Zero-copy TCP RX&lt;/b&gt;&lt;hr&gt;Replace flat rx_buf with&lt;br&gt;netbuf queue." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#FFE0B2;strokeColor=#E65100;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1160" y="830" width="200" height="140" as="geometry" />
        </mxCell>
        <!-- ═══════════ TIER 4 ═══════════ -->
        <mxCell id="t4_group" value="" style="html=1;rounded=1;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=3;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="40" y="1025" width="1520" height="270" as="geometry" />
        </mxCell>
        <mxCell id="t4_label" value="TIER 4 — Advanced OS Features (Lower Priority, High Effort)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="60" y="1035" width="550" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t4_priority" value="STRETCH GOALS" style="text;html=1;fontSize=13;fontStyle=1;align=right;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="1350" y="1035" width="190" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t4_1" value="&lt;b&gt;Futex / Mutex&lt;/b&gt;&lt;hr&gt;User-space synchronization.&lt;br&gt;Fast user path, slow kernel&lt;br&gt;wait queue path." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="1075" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t4_2" value="&lt;b&gt;pthreads Library&lt;/b&gt;&lt;hr&gt;pthread_create/join/mutex.&lt;br&gt;Requires kernel thread or&lt;br&gt;clone() support." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="255" y="1075" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t4_3" value="&lt;b&gt;Shared Memory&lt;/b&gt;&lt;hr&gt;shmget/shmat or shm_open.&lt;br&gt;Fast zero-copy IPC for&lt;br&gt;cooperating processes." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="450" y="1075" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t4_4" value="&lt;b&gt;NVMe Driver&lt;/b&gt;&lt;hr&gt;Modern SSD interface.&lt;br&gt;Queue-based, MSI-X&lt;br&gt;interrupts." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="645" y="1075" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t4_5" value="&lt;b&gt;Sound (AC97/HDA)&lt;/b&gt;&lt;hr&gt;Audio output via AC97 or&lt;br&gt;Intel HD Audio. PCM&lt;br&gt;playback, DMA buffers." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="840" y="1075" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="t4_6" value="&lt;b&gt;TLS / SSL&lt;/b&gt;&lt;hr&gt;HTTPS support. Crypto&lt;br&gt;primitives, TLS 1.2+&lt;br&gt;handshake, certificates." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
