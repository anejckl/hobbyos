        <mxCell id="t4_8" value="&lt;b&gt;Slab Allocator&lt;/b&gt;&lt;hr&gt;Object caches for common&lt;br&gt;sizes (PCB, page tables).&lt;br&gt;Upgrade from free-list." style="html=1;rounded=1;whiteSpace=wrap;fillColor=#E1BEE7;strokeColor=#6A1B9A;align=left;spacingLeft=8;spacingRight=8;verticalAlign=top;" vertex="1" parent="1">
